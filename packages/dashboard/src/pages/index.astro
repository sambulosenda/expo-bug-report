    }
    .inline-code {
      background: var(--surface);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 13px;
      color: var(--text);
    }

    /* ===== Footer ===== */
    .site-footer {
      border-top: 1px solid var(--border);
      padding: 48px 0;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 40px;
    }
    .footer-logo {
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }
    .footer-brand p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.5;
    }
    .footer-license {
      margin-top: 8px;
      font-size: 12px;
      color: var(--text-muted);
    }
    .footer-col h4 {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 12px;
    }
    .footer-col a {
      display: block;
      font-size: 14px;
      color: var(--text-muted);
      padding: 3px 0;
      transition: color 0.15s;
    }
    .footer-col a:hover { color: var(--text); }
    .footer-bottom {
      margin-top: 40px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: var(--text-muted);
      text-align: center;
    }

    /* ===== Scroll Reveal ===== */
    .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }

    /* ===== Responsive ===== */
    @media (max-width: 1024px) {
      .hero-inner { grid-template-columns: 1fr; gap: 48px; }
      .hero { padding: 60px 24px 40px; }
      .hero-inner { min-height: auto; }
      .feature-row,
      .feature-row-reverse { grid-template-columns: 1fr; gap: 32px; }
      .feature-row-reverse { direction: ltr; }
      .code-section-inner { grid-template-columns: 1fr; }
      .pricing-grid { grid-template-columns: 1fr; }
      .how-grid { grid-template-columns: 1fr; gap: 32px; }
      .how-header { position: static; }
      .signup-layout { grid-template-columns: 1fr; gap: 32px; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .nav-toggle-label { display: block; }
      .nav-links {
        display: none;
        position: absolute;
        top: 64px;
        left: 0;
        right: 0;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        flex-direction: column;
        gap: 12px;
      }
      .nav-toggle-input:checked ~ .nav-links { display: flex; }
      .hero-headline { font-size: 36px; }
      .hero-visual { display: none; }
      .section-title { font-size: 28px; }
      .signup-visual { display: none; }
      .footer-grid { grid-template-columns: 1fr; gap: 24px; }
    }

    @media (max-width: 480px) {
      .hero-headline { font-size: 28px; }
      .hero-cta { flex-direction: column; }
      .hero-cta .btn { text-align: center; justify-content: center; }
      .logos { gap: 16px; }
      .logos-row { gap: 16px; }
      .signup-form { flex-direction: column; gap: 8px; }
      .signup-input { border-radius: var(--radius); border-right: 1px solid var(--border); }
      .signup-btn { border-radius: var(--radius) !important; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>

  <script is:inline>
    // Scroll reveal
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });

    // Stripe links
    var STRIPE_STARTER_LINK = 'https://buy.stripe.com/test_fZu4gAe320EN4vK9ejbwk01';
    var STRIPE_PRO_LINK = 'https://buy.stripe.com/test_3cIfZiaQQevD4vK3TZbwk00';

    function showPricingLinks(email) {
      if (!STRIPE_STARTER_LINK || !STRIPE_PRO_LINK) return;
      var starterLink = document.getElementById('starter-link');
      var proLink = document.getElementById('pro-link');
      if (starterLink) {
        starterLink.href = STRIPE_STARTER_LINK + '?prefilled_email=' + encodeURIComponent(email);
      }
      if (proLink) {
        proLink.href = STRIPE_PRO_LINK + '?prefilled_email=' + encodeURIComponent(email);
      }
    }

    // Signup
    document.getElementById('signup-btn').addEventListener('click', async function() {
      var emailInput = document.getElementById('email');
      var email = emailInput.value.trim();
      if (!email || !email.includes('@')) { alert('Enter a valid email.'); return; }

      var btn = document.getElementById('signup-btn');
      btn.disabled = true;
      btn.textContent = 'Creating...';

      try {
        var res = await fetch(window.__BUGPULSE_API + '/v1/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });

        if (res.status === 409) {
          alert('This email is already registered. Use the CLI to recover your keys: npx @bugpulse/cli recover');
          return;
        }

        if (!res.ok) { alert('Signup failed. Try again.'); return; }

        var data = await res.json();
        document.getElementById('api-key').textContent = data.api_key;
        document.getElementById('hmac-secret').textContent = data.hmac_secret;
        document.getElementById('result').style.display = 'block';
        btn.textContent = 'Done';
        showPricingLinks(email);
      } catch(e) {
        alert('Network error. Check your connection.');
      } finally {
        btn.disabled = false;
        if (btn.textContent !== 'Done') btn.textContent = 'Get API Key';
      }
    });

    // Copy buttons — uses class toggle, no innerHTML
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.dataset.target;
        var text = document.getElementById(target) ? document.getElementById(target).textContent : '';
        if (text) {
          navigator.clipboard.writeText(text);
          btn.classList.add('copied');
          setTimeout(function() { btn.classList.remove('copied'); }, 1500);
        }
      });
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(function(a) {
      a.addEventListener('click', function(e) {
        var href = a.getAttribute('href');
        if (href && href.length > 1) {
          var target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth' });
            var toggle = document.getElementById('nav-toggle');
            if (toggle) toggle.checked = false;
          }
        }
      });
    });
  </script>
</Layout>
