---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Reports" pageTitle="BUGPULSE">
  <div class="dashboard">
    <!-- Left: Bug Feed -->
    <section class="feed-section">
      <div class="feed-header">
        <h2 class="feed-title">Bug Feed</h2>
        <div class="feed-controls">
          <select id="severity-filter">
            <option value="">All severities</option>
            <option value="crash">Crash</option>
            <option value="error">Error</option>
            <option value="feedback">Feedback</option>
          </select>
          <select id="status-filter">
            <option value="">All statuses</option>
            <option value="new">New</option>
            <option value="triaged">Triaged</option>
            <option value="fixed">Fixed</option>
          </select>
          <button class="btn btn-sm" id="refresh-btn">Refresh</button>
        </div>
      </div>
      <div class="poll-status" id="poll-status">Auto-refreshing every 15s</div>

      <div id="report-list"></div>
      <div id="empty-state" class="empty-state" hidden>
        <h2>No reports yet</h2>
        <p>Set up BugPulse in your app to start receiving reports.</p>
        <pre><code>npm install @bugpulse/react-native
npx @bugpulse/cli init</code></pre>
        <p style="margin-top:16px;color:var(--text-muted);font-size:13px;">
          Reports will appear here automatically once your app starts sending them.
        </p>
      </div>
    </section>

    <!-- Right: Stats Panel -->
    <aside class="stats-panel" id="stats-panel">
      <div class="hero-stat">
        <div class="hero-stat-number" id="stat-total">--</div>
        <div class="hero-stat-label">Total Reports</div>
      </div>

      <div class="sparkline-container">
        <svg class="sparkline-svg" viewBox="0 0 180 40" preserveAspectRatio="none">
          <path id="sparkline-path" d="" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="sparkline-meta">
          <span class="sparkline-label">Last 7 days</span>
          <span class="sparkline-total" id="sparkline-total"></span>
        </div>
      </div>

      <div class="section-label">Breakdown</div>
      <div class="mini-stats">
        <div class="mini-stat">
          <span class="mini-stat-label">Crashes</span>
          <span class="mini-stat-value critical" id="stat-crash">--</span>
        </div>
        <div class="mini-stat">
          <span class="mini-stat-label">Errors</span>
          <span class="mini-stat-value warning" id="stat-error">--</span>
        </div>
        <div class="mini-stat">
          <span class="mini-stat-label">Feedback</span>
          <span class="mini-stat-value info" id="stat-feedback">--</span>
        </div>
      </div>

      <div class="section-label" id="top-screens-section" hidden>Top Screens</div>
      <div class="top-screens-list" id="top-screens"></div>
    </aside>
  </div>

  <style>
    /* ===== Dashboard Grid ===== */
    .dashboard {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 32px;
    }

    /* ===== Feed Section ===== */
    .feed-section {
      display: flex;
      flex-direction: column;
      gap: 12px;
      min-width: 0;
    }
    .feed-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .feed-title {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .feed-controls {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .poll-status {
      font-size: 11px;
      color: var(--text-ghost);
      font-family: var(--font-mono);
    }

    /* ===== Bug Cards ===== */
    .bug-card {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: 16px;
      padding: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      transition: transform 75ms ease-out, border-color 150ms ease-out;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      animation: slideInLeft 300ms ease-out both;
    }
    .bug-card:hover {
      transform: translateY(-1px);
      border-color: var(--accent);
    }
    .bug-card.new-report {
      animation: highlight 2s ease;
    }
    @keyframes slideInLeft {
      from { opacity: 0; transform: translateX(-12px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes highlight {
      0% { border-color: var(--accent); background: var(--accent-muted); }
      100% { border-color: var(--border); background: var(--surface); }
    }

    .bug-card-thumb {
      width: 100px;
      height: 68px;
      background: var(--inset);
      border-radius: 2px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .bug-card-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .bug-card-thumb-content {
      width: calc(100% - 8px);
      height: calc(100% - 8px);
      border: 1px solid var(--border);
      border-radius: 2px;
      display: flex;
      flex-direction: column;
      padding: 4px;
      gap: 3px;
      overflow: hidden;
    }
    .thumb-line {
      height: 2px;
      background: var(--text-ghost);
      opacity: 0.3;
      border-radius: 1px;
    }
    .thumb-line:nth-child(1) { width: 70%; }
    .thumb-line:nth-child(2) { width: 50%; }
    .thumb-line:nth-child(3) { width: 85%; }
    .thumb-line:nth-child(4) { width: 40%; }
    .thumb-line.accent { background: var(--red); opacity: 0.6; }

    .bug-card-body {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }
    .bug-card-title {
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bug-card-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--text-ghost);
    }
    .severity-dot {
      width: 6px;
      height: 6px;
      border-radius: 9999px;
      flex-shrink: 0;
    }
    .severity-critical { background: var(--red); }
    .severity-warning { background: var(--yellow); }
    .severity-info { background: var(--info); }
    .severity-feedback { background: var(--accent); }

    .bug-card-screen {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-muted);
    }
    .bug-card-time {
      font-family: var(--font-mono);
      font-size: 11px;
    }
    .bug-card-tags {
      display: flex;
      gap: 4px;
      margin-top: 4px;
    }
    .tag {
      font-family: var(--font-mono);
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 2px;
      background: var(--inset);
      color: var(--text-muted);
      border: 1px solid var(--border-subtle);
    }

    /* ===== Stats Panel ===== */
    .stats-panel {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .hero-stat {
      text-align: right;
      padding: 24px 0;
    }
    .hero-stat-number {
      font-family: var(--font-display);
      font-size: 96px;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
      letter-spacing: -0.04em;
      font-variant-numeric: tabular-nums;
    }
    .hero-stat-label {
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-ghost);
      margin-top: 8px;
    }

    /* Sparkline */
    .sparkline-container {
      text-align: right;
    }
    .sparkline-svg {
      width: 180px;
      height: 40px;
      display: inline-block;
    }
    .sparkline-meta {
      display: flex;
      justify-content: space-between;
      margin-top: 4px;
    }
    .sparkline-label, .sparkline-total {
      font-size: 11px;
      color: var(--text-ghost);
      font-family: var(--font-mono);
    }

    /* Section label */
    .section-label {
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-ghost);
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border-subtle);
    }

    /* Mini stats */
    .mini-stats {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .mini-stat {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .mini-stat-label {
      font-family: var(--font-body);
      font-size: 13px;
      color: var(--text-muted);
    }
    .mini-stat-value {
      font-family: var(--font-mono);
      font-size: 14px;
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    .mini-stat-value.critical { color: var(--red); }
    .mini-stat-value.warning { color: var(--yellow); }
    .mini-stat-value.info { color: var(--info); }

    /* Top screens */
    .top-screens-list {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .screen-pill {
      padding: 4px 10px;
      border-radius: var(--radius);
      font-size: 11px;
      font-family: var(--font-mono);
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text-muted);
      cursor: pointer;
      transition: border-color 150ms ease-out, color 150ms ease-out;
    }
    .screen-pill:hover { border-color: var(--accent); color: var(--text); }
    .screen-pill-count {
      color: var(--accent);
      margin-left: 4px;
      font-family: var(--font-body);
    }
    .screen-pill-active {
      border-color: var(--accent);
      color: var(--text);
      background: var(--accent-muted);
    }
    .screen-pill-clear {
      color: var(--text-muted);
      font-family: var(--font-body);
      font-style: italic;
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 80px 20px;
    }
    .empty-state h2 { margin-bottom: 12px; font-family: var(--font-display); }
    .empty-state pre {
      display: inline-block;
      text-align: left;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-top: 16px;
      font-family: var(--font-mono);
      font-size: 13px;
    }

    /* ===== Responsive ===== */
    @media (max-width: 1024px) {
      .dashboard { grid-template-columns: 1fr; }
      .stats-panel {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 16px;
      }
      .hero-stat { text-align: left; }
      .hero-stat-number { font-size: 64px; }
      .sparkline-container { text-align: left; }
      .mini-stats { flex: 1; min-width: 200px; }
    }
    @media (max-width: 768px) {
      .bug-card { grid-template-columns: 72px 1fr; }
      .bug-card-thumb { width: 72px; height: 52px; }
      .hero-stat-number { font-size: 48px; }
    }
  </style>

  <script>
    const reportList = document.getElementById('report-list')!;
    const emptyState = document.getElementById('empty-state')!;
    const severityFilter = document.getElementById('severity-filter') as HTMLSelectElement;
    const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
    const pollStatus = document.getElementById('poll-status')!;
    const refreshBtn = document.getElementById('refresh-btn')!;

    let reports: any[] = [];
    let pollTimer: ReturnType<typeof setInterval>;

    const statTotal = document.getElementById('stat-total')!;
    const statCrash = document.getElementById('stat-crash')!;
    const statError = document.getElementById('stat-error')!;
    const statFeedback = document.getElementById('stat-feedback')!;
    const sparklinePath = document.getElementById('sparkline-path')!;
    const sparklineTotal = document.getElementById('sparkline-total')!;
    const topScreensSection = document.getElementById('top-screens-section')!;
    const topScreensEl = document.getElementById('top-screens')!;

    async function fetchAnalytics() {
      try {
        const res = await window.__bp.fetch('/v1/analytics');
        if (!res.ok) return;
        const data = await res.json();

        const sev = data.severityBreakdown || {};
        const total = (sev.crash || 0) + (sev.error || 0) + (sev.feedback || 0);

        statTotal.textContent = String(total);
        statCrash.textContent = String(sev.crash || 0);
        statError.textContent = String(sev.error || 0);
        statFeedback.textContent = String(sev.feedback || 0);

        // SVG sparkline
        const days: {date: string; count: number}[] = data.volumeByDay || [];
        if (days.length > 0) {
          const max = Math.max(...days.map((d: any) => d.count), 1);
          const dayTotal = days.reduce((s: number, d: any) => s + d.count, 0);
          sparklineTotal.textContent = `${dayTotal} reports`;

          const points = days.map((d, i) => {
            const x = days.length > 1 ? (i / (days.length - 1)) * 180 : 90;
            const y = 40 - (d.count / max) * 36;
            return `${x.toFixed(1)},${y.toFixed(1)}`;
          });
          sparklinePath.setAttribute('d', 'M' + points.join(' L'));
        }

        // Top screens
        const screens: {screen: string; count: number}[] = data.topScreens || [];
        if (screens.length > 0) {
          topScreensSection.hidden = false;
          const fragment = document.createDocumentFragment();
          for (const s of screens.slice(0, 5)) {
            const pill = document.createElement('span');
            pill.className = 'screen-pill';
            pill.textContent = s.screen;

            const count = document.createElement('span');
            count.className = 'screen-pill-count';
            count.textContent = String(s.count);
            pill.appendChild(count);

            pill.addEventListener('click', () => {
              topScreensEl.querySelectorAll('.screen-pill').forEach((p: Element) => p.classList.remove('screen-pill-active'));
              pill.classList.add('screen-pill-active');
              const sev = severityFilter.value;
              const stat = statusFilter.value;
              const filtered = reports.filter((r: any) =>
                r.screen === s.screen && (!sev || r.severity === sev) && (!stat || r.status === stat)
              );
              emptyState.hidden = true;
              const frag = document.createDocumentFragment();
              for (const r of filtered) {
                frag.appendChild(createReportCard(r));
              }
              reportList.replaceChildren(frag);
            });

            fragment.appendChild(pill);
          }

          const clearPill = document.createElement('span');
          clearPill.className = 'screen-pill screen-pill-clear';
          clearPill.textContent = 'Show all';
          clearPill.addEventListener('click', () => {
            topScreensEl.querySelectorAll('.screen-pill').forEach((p: Element) => p.classList.remove('screen-pill-active'));
            renderReports();
          });
          fragment.appendChild(clearPill);

          topScreensEl.replaceChildren(fragment);
        }
      } catch {
        // Silent fail — analytics is supplementary
      }
    }

    function timeAgo(dateStr: string): string {
      const diff = Date.now() - new Date(dateStr).getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'just now';
      if (mins < 60) return `${mins}m ago`;
      const hours = Math.floor(mins / 60);
      if (hours < 24) return `${hours}h ago`;
      const days = Math.floor(hours / 24);
      return `${days}d ago`;
    }

    const sevMap: Record<string, string> = { crash: 'critical', error: 'warning', feedback: 'feedback' };

    function createReportCard(r: any): HTMLAnchorElement {
      const card = document.createElement('a');
      card.href = `/report?id=${r.id}`;
      card.className = 'bug-card';

      // Thumbnail
      const thumb = document.createElement('div');
      thumb.className = 'bug-card-thumb';
      if (r.screenshot_id) {
        const img = document.createElement('img');
        img.src = `/v1/screenshots/${r.screenshot_id}`;
        img.alt = 'Screenshot';
        thumb.appendChild(img);
      } else {
        const content = document.createElement('div');
        content.className = 'bug-card-thumb-content';
        for (let i = 0; i < 4; i++) {
          const line = document.createElement('div');
          line.className = 'thumb-line' + (r.severity === 'crash' && i === 1 ? ' accent' : '');
          content.appendChild(line);
        }
        thumb.appendChild(content);
      }

      // Body
      const body = document.createElement('div');
      body.className = 'bug-card-body';

      const title = document.createElement('h3');
      title.className = 'bug-card-title';
      title.textContent = r.description || 'No description';

      const meta = document.createElement('div');
      meta.className = 'bug-card-meta';

      const dot = document.createElement('span');
      dot.className = `severity-dot severity-${sevMap[r.severity] || 'info'}`;
      const screen = document.createElement('span');
      screen.className = 'bug-card-screen';
      screen.textContent = r.screen || 'unknown';
      const time = document.createElement('span');
      time.className = 'bug-card-time';
      time.textContent = timeAgo(r.created_at);
      meta.append(dot, screen, time);

      const tags = document.createElement('div');
      tags.className = 'bug-card-tags';
      const sevTag = document.createElement('span');
      sevTag.className = 'tag';
      sevTag.textContent = r.severity;
      const statTag = document.createElement('span');
      statTag.className = 'tag';
      statTag.textContent = r.status;
      tags.append(sevTag, statTag);

      body.append(title, meta, tags);
      card.append(thumb, body);
      return card;
    }

    function renderReports() {
      const sev = severityFilter.value;
      const stat = statusFilter.value;
      const filtered = reports.filter(r =>
        (!sev || r.severity === sev) && (!stat || r.status === stat)
      );

      if (filtered.length === 0 && reports.length === 0) {
        reportList.replaceChildren();
        emptyState.hidden = false;
        return;
      }

      emptyState.hidden = true;
      const fragment = document.createDocumentFragment();
      for (const r of filtered) {
        fragment.appendChild(createReportCard(r));
      }
      reportList.replaceChildren(fragment);
    }

    async function fetchReports() {
      try {
        const res = await window.__bp.fetch('/v1/dashboard/reports?limit=50');
        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }
        if (!res.ok) return;

        const data = await res.json();
        const prevCount = reports.length;
        reports = data.reports || [];
        renderReports();

        if (prevCount > 0 && reports.length > prevCount) {
          const newCards = reportList.querySelectorAll('.bug-card');
          for (let i = 0; i < reports.length - prevCount; i++) {
            newCards[i]?.classList.add('new-report');
          }
        }

        pollStatus.textContent = `Updated ${new Date().toLocaleTimeString()} · Auto-refreshing every 15s`;
      } catch {
        pollStatus.textContent = 'Connection error · Retrying...';
      }
    }

    fetchReports();
    fetchAnalytics();
    pollTimer = setInterval(() => { fetchReports(); fetchAnalytics(); }, 15000);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearInterval(pollTimer);
      } else {
        fetchReports();
        fetchAnalytics();
        pollTimer = setInterval(() => { fetchReports(); fetchAnalytics(); }, 15000);
      }
    });

    severityFilter.addEventListener('change', renderReports);
    statusFilter.addEventListener('change', renderReports);
    refreshBtn.addEventListener('click', () => { fetchReports(); fetchAnalytics(); });
  </script>
</DashboardLayout>
