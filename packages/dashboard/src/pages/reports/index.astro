---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Reports">
  <header class="header">
    <h1>BugPulse</h1>
    <div style="display:flex;gap:8px;align-items:center;">
      <a href="/team" class="btn" id="team-link">Team</a>
      <button class="btn" id="refresh-btn">Refresh</button>
      <button class="btn" id="logout-btn">Logout</button>
    </div>
  </header>

  <div class="container">
    <!-- Analytics Overview -->
    <div id="analytics-section" class="analytics-section" hidden>
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-number" id="stat-total">—</div>
          <div class="stat-label">Total Reports</div>
        </div>
        <div class="stat-card stat-card-crash">
          <div class="stat-indicator" style="background:var(--red)"></div>
          <div class="stat-number" id="stat-crash">—</div>
          <div class="stat-label">Crashes</div>
        </div>
        <div class="stat-card stat-card-error">
          <div class="stat-indicator" style="background:var(--yellow)"></div>
          <div class="stat-number" id="stat-error">—</div>
          <div class="stat-label">Errors</div>
        </div>
        <div class="stat-card stat-card-feedback">
          <div class="stat-indicator" style="background:var(--accent)"></div>
          <div class="stat-number" id="stat-feedback">—</div>
          <div class="stat-label">Feedback</div>
        </div>
      </div>

      <div class="sparkline-section">
        <div class="sparkline-header">
          <span class="sparkline-title">Last 7 days</span>
          <span class="sparkline-total" id="sparkline-total"></span>
        </div>
        <div class="sparkline" id="sparkline"></div>
      </div>

      <div class="top-screens" id="top-screens-section" hidden>
        <span class="top-screens-label">Top screens</span>
        <div class="top-screens-list" id="top-screens"></div>
      </div>
    </div>

    <div class="toolbar">
      <div class="filters">
        <select id="severity-filter">
          <option value="">All severities</option>
          <option value="crash">Crash</option>
          <option value="error">Error</option>
          <option value="feedback">Feedback</option>
        </select>
        <select id="status-filter">
          <option value="">All statuses</option>
          <option value="new">New</option>
          <option value="triaged">Triaged</option>
          <option value="fixed">Fixed</option>
        </select>
      </div>
      <div class="poll-status" id="poll-status">Auto-refreshing every 15s</div>
    </div>

    <div id="report-list"></div>
    <div id="empty-state" class="empty-state" hidden>
      <h2>No reports yet</h2>
      <p>Set up BugPulse in your app to start receiving reports.</p>
      <pre><code>npm install @bugpulse/react-native
npx @bugpulse/cli init</code></pre>
      <p style="margin-top:16px;color:var(--text-muted);font-size:13px;">
        Reports will appear here automatically once your app starts sending them.
      </p>
    </div>
  </div>

  <style>
    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
      flex-wrap: wrap;
      gap: 12px;
    }
    .filters { display: flex; gap: 8px; }
    .poll-status { font-size: 12px; color: var(--text-muted); }

    .report-card {
      display: grid;
      grid-template-columns: auto 1fr auto auto;
      gap: 12px;
      align-items: center;
      padding: 14px 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 8px;
      cursor: pointer;
      transition: border-color 0.15s;
      text-decoration: none;
      color: inherit;
    }
    .report-card:hover { border-color: var(--accent); }
    .report-card.new-report {
      animation: highlight 2s ease;
    }

    @keyframes highlight {
      0% { border-color: var(--accent); background: rgba(99,102,241,0.08); }
      100% { border-color: var(--border); background: var(--surface); }
    }

    .report-screen {
      font-family: monospace;
      font-size: 13px;
      color: var(--text-muted);
    }
    .report-desc {
      font-size: 14px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .report-time {
      font-size: 12px;
      color: var(--text-muted);
      white-space: nowrap;
    }

    /* Analytics */
    .analytics-section {
      margin-bottom: 20px;
    }
    .stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      position: relative;
    }
    .stat-indicator {
      width: 4px;
      height: 100%;
      position: absolute;
      left: 0;
      top: 0;
      border-radius: var(--radius) 0 0 var(--radius);
    }
    .stat-number {
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
    }
    .stat-label {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 2px;
    }

    .sparkline-section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 16px;
    }
    .sparkline-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }
    .sparkline-title {
      font-size: 13px;
      color: var(--text-muted);
    }
    .sparkline-total {
      font-size: 13px;
      color: var(--text-muted);
    }
    .sparkline {
      display: flex;
      align-items: flex-end;
      gap: 4px;
      height: 64px;
    }
    .sparkline-bar-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      height: 100%;
      justify-content: flex-end;
    }
    .sparkline-bar {
      width: 100%;
      background: var(--accent);
      border-radius: 3px 3px 0 0;
      min-height: 2px;
      transition: height 0.3s ease;
      opacity: 0.7;
    }
    .sparkline-bar:hover { opacity: 1; }
    .sparkline-day {
      font-size: 10px;
      color: var(--text-muted);
    }

    .top-screens {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .top-screens-label {
      font-size: 12px;
      color: var(--text-muted);
    }
    .top-screens-list {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .screen-pill {
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-family: monospace;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text-muted);
      cursor: pointer;
      transition: 0.15s;
    }
    .screen-pill:hover {
      border-color: var(--accent);
      color: var(--text);
    }
    .screen-pill-count {
      color: var(--accent);
      margin-left: 4px;
      font-family: -apple-system, sans-serif;
    }

    @media (max-width: 640px) {
      .stats-row { grid-template-columns: repeat(2, 1fr); }
    }

    .empty-state {
      text-align: center;
      padding: 80px 20px;
    }
    .empty-state h2 { margin-bottom: 12px; }
    .empty-state pre {
      display: inline-block;
      text-align: left;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-top: 16px;
      font-size: 13px;
    }
  </style>

  <script>
    const reportList = document.getElementById('report-list')!;
    const emptyState = document.getElementById('empty-state')!;
    const severityFilter = document.getElementById('severity-filter') as HTMLSelectElement;
    const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
    const pollStatus = document.getElementById('poll-status')!;
    const refreshBtn = document.getElementById('refresh-btn')!;
    const logoutBtn = document.getElementById('logout-btn')!;

    let reports: any[] = [];
    let pollTimer: ReturnType<typeof setInterval>;

    const analyticsSection = document.getElementById('analytics-section')!;
    const statTotal = document.getElementById('stat-total')!;
    const statCrash = document.getElementById('stat-crash')!;
    const statError = document.getElementById('stat-error')!;
    const statFeedback = document.getElementById('stat-feedback')!;
    const sparklineEl = document.getElementById('sparkline')!;
    const sparklineTotal = document.getElementById('sparkline-total')!;
    const topScreensSection = document.getElementById('top-screens-section')!;
    const topScreensEl = document.getElementById('top-screens')!;

    async function fetchAnalytics() {
      try {
        const res = await window.__bp.fetch('/v1/analytics');
        if (!res.ok) return;
        const data = await res.json();

        const sev = data.severityBreakdown || {};
        const total = (sev.crash || 0) + (sev.error || 0) + (sev.feedback || 0);

        statTotal.textContent = String(total);
        statCrash.textContent = String(sev.crash || 0);
        statError.textContent = String(sev.error || 0);
        statFeedback.textContent = String(sev.feedback || 0);

        // Sparkline
        const days: {date: string; count: number}[] = data.volumeByDay || [];
        if (days.length > 0) {
          const max = Math.max(...days.map((d: any) => d.count), 1);
          const dayTotal = days.reduce((s: number, d: any) => s + d.count, 0);
          sparklineTotal.textContent = `${dayTotal} reports`;

          const fragment = document.createDocumentFragment();
          for (const d of days) {
            const wrap = document.createElement('div');
            wrap.className = 'sparkline-bar-wrap';

            const bar = document.createElement('div');
            bar.className = 'sparkline-bar';
            bar.style.height = `${Math.max((d.count / max) * 100, 3)}%`;
            bar.title = `${d.date}: ${d.count} reports`;

            const label = document.createElement('span');
            label.className = 'sparkline-day';
            const dt = new Date(d.date + 'T00:00:00');
            label.textContent = dt.toLocaleDateString('en', { weekday: 'short' }).slice(0, 3);

            wrap.appendChild(bar);
            wrap.appendChild(label);
            fragment.appendChild(wrap);
          }
          sparklineEl.replaceChildren(fragment);
        }

        // Top screens
        const screens: {screen: string; count: number}[] = data.topScreens || [];
        if (screens.length > 0) {
          topScreensSection.hidden = false;
          const fragment = document.createDocumentFragment();
          for (const s of screens.slice(0, 5)) {
            const pill = document.createElement('span');
            pill.className = 'screen-pill';
            pill.textContent = s.screen;

            const count = document.createElement('span');
            count.className = 'screen-pill-count';
            count.textContent = String(s.count);
            pill.appendChild(count);

            pill.addEventListener('click', () => {
              // Filter reports to this screen
              const sev = severityFilter.value;
              const stat = statusFilter.value;
              const filtered = reports.filter((r: any) =>
                r.screen === s.screen && (!sev || r.severity === sev) && (!stat || r.status === stat)
              );
              emptyState.hidden = true;
              const frag = document.createDocumentFragment();
              for (const r of filtered) {
                frag.appendChild(createReportCard(r));
              }
              reportList.replaceChildren(frag);
            });

            fragment.appendChild(pill);
          }
          topScreensEl.replaceChildren(fragment);
        }

        if (total > 0) {
          analyticsSection.hidden = false;
        }
      } catch {
        // Silent fail — analytics is supplementary
      }
    }

    function timeAgo(dateStr: string): string {
      const diff = Date.now() - new Date(dateStr).getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'just now';
      if (mins < 60) return `${mins}m ago`;
      const hours = Math.floor(mins / 60);
      if (hours < 24) return `${hours}h ago`;
      const days = Math.floor(hours / 24);
      return `${days}d ago`;
    }

    function createReportCard(r: any): HTMLAnchorElement {
      const card = document.createElement('a');
      card.href = `/report?id=${r.id}`;
      card.className = 'report-card';

      const sevBadge = document.createElement('span');
      sevBadge.className = `badge badge-${r.severity}`;
      sevBadge.textContent = r.severity;

      const content = document.createElement('div');
      const desc = document.createElement('div');
      desc.className = 'report-desc';
      desc.textContent = r.description || 'No description';
      const screen = document.createElement('div');
      screen.className = 'report-screen';
      screen.textContent = r.screen || 'unknown';
      content.appendChild(desc);
      content.appendChild(screen);

      const statusBadge = document.createElement('span');
      statusBadge.className = `badge badge-${r.status}`;
      statusBadge.textContent = r.status;

      const time = document.createElement('span');
      time.className = 'report-time';
      time.textContent = timeAgo(r.created_at);

      card.appendChild(sevBadge);
      card.appendChild(content);
      card.appendChild(statusBadge);
      card.appendChild(time);

      return card;
    }

    function renderReports() {
      const sev = severityFilter.value;
      const stat = statusFilter.value;
      const filtered = reports.filter(r =>
        (!sev || r.severity === sev) && (!stat || r.status === stat)
      );

      if (filtered.length === 0 && reports.length === 0) {
        reportList.replaceChildren();
        emptyState.hidden = false;
        return;
      }

      emptyState.hidden = true;
      const fragment = document.createDocumentFragment();
      for (const r of filtered) {
        fragment.appendChild(createReportCard(r));
      }
      reportList.replaceChildren(fragment);
    }

    async function fetchReports() {
      try {
        const res = await window.__bp.fetch('/v1/dashboard/reports?limit=50');
        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }
        if (!res.ok) return;

        const data = await res.json();
        const prevCount = reports.length;
        reports = data.reports || [];
        renderReports();

        if (prevCount > 0 && reports.length > prevCount) {
          const newCards = reportList.querySelectorAll('.report-card');
          for (let i = 0; i < reports.length - prevCount; i++) {
            newCards[i]?.classList.add('new-report');
          }
        }

        pollStatus.textContent = `Updated ${new Date().toLocaleTimeString()} \u00b7 Auto-refreshing every 15s`;
      } catch {
        pollStatus.textContent = 'Connection error \u00b7 Retrying...';
      }
    }

    fetchReports();
    fetchAnalytics();
    pollTimer = setInterval(() => { fetchReports(); fetchAnalytics(); }, 15000);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearInterval(pollTimer);
      } else {
        fetchReports();
        fetchAnalytics();
        pollTimer = setInterval(() => { fetchReports(); fetchAnalytics(); }, 15000);
      }
    });

    severityFilter.addEventListener('change', renderReports);
    statusFilter.addEventListener('change', renderReports);
    refreshBtn.addEventListener('click', () => { fetchReports(); fetchAnalytics(); });

    logoutBtn.addEventListener('click', async () => {
      await window.__bp.fetch('/v1/auth/logout', { method: 'POST' });
      window.__bp.logout();
      window.location.href = '/login';
    });
  </script>
</Layout>
