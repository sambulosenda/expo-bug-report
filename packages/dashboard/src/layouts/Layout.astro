---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - BugPulse</title>
    <script is:inline src="/config.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap" rel="stylesheet">
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --bg: #1A1814;
        --surface: #242019;
        --surface-hover: #2E2A22;
        --inset: #141210;
        --border: #3D372F;
        --border-subtle: #2E2A2233;
        --text: #E8E0D4;
        --text-muted: #9B9183;
        --text-ghost: #5C554B;
        --accent: #E86B2E;
        --accent-hover: #F07A3E;
        --accent-muted: #E86B2E26;
        --green: #5BA865;
        --yellow: #E8A02E;
        --red: #D94B4B;
        --info: #5B8FA8;
        --radius: 4px;
        --font-display: 'Space Grotesk', sans-serif;
        --font-body: 'General Sans', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        --nav-rail-width: 48px;
        --nav-rail-expanded: 200px;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.02'/%3E%3C/svg%3E");
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-hover); }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px;
      }

.btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: transform 75ms ease-out, box-shadow 150ms ease-out, background 150ms ease-out;
      }
      .btn:hover { background: var(--surface-hover); transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
      .btn-primary {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--bg);
      }
      .btn-primary:hover { background: var(--accent-hover); }

      .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: var(--radius);
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .badge-crash { background: rgba(217, 75, 75, 0.15); color: var(--red); }
      .badge-error { background: rgba(232, 160, 46, 0.15); color: var(--yellow); }
      .badge-feedback { background: rgba(232, 107, 46, 0.15); color: var(--accent); }

      .badge-new { background: rgba(232, 107, 46, 0.15); color: var(--accent); }
      .badge-triaged { background: rgba(232, 160, 46, 0.15); color: var(--yellow); }
      .badge-fixed { background: rgba(91, 168, 101, 0.15); color: var(--green); }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
      }

      input, select {
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--inset);
        color: var(--text);
        font-family: var(--font-body);
        font-size: 13px;
        transition: transform 75ms ease-out, border-color 150ms ease-out;
      }
      input:focus, select:focus {
        outline: none;
        border-color: var(--accent);
        transform: translateY(1px);
      }

      .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 12px 20px;
        border-radius: var(--radius);
        background: var(--surface);
        border: 1px solid var(--border);
        font-family: var(--font-body);
        font-size: 13px;
        z-index: 100;
        animation: slideIn 0.3s ease-out;
      }
      .toast-success { border-color: var(--green); }
      .toast-error { border-color: var(--red); }

      @keyframes slideIn {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
