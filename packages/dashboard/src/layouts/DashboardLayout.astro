---
import Layout from './Layout.astro';

interface Props {
  title: string;
  pageTitle?: string;
}

const { title, pageTitle } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/reports', label: 'Dashboard', icon: 'grid', match: (p: string) => p === '/reports' || p === '/reports/' },
  { href: '/team', label: 'Team', icon: 'team', match: (p: string) => p.startsWith('/team') },
  { href: '/integrations', label: 'Integrations', icon: 'integrations', match: (p: string) => p.startsWith('/integrations') },
];
---

<Layout title={title}>
  <nav class="nav-rail" aria-label="Main navigation">
    <div class="nav-rail-logo">
      <svg viewBox="0 0 24 24" fill="var(--accent)" width="20" height="20"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
    </div>

    {navItems.map(item => (
      <a class:list={['nav-item', { active: item.match(currentPath) }]} href={item.href}>
        {item.icon === 'grid' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>}
        {item.icon === 'team' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>}
        {item.icon === 'integrations' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/></svg>}
        <span class="nav-item-label">{item.label}</span>
      </a>
    ))}

    <div class="nav-spacer"></div>

    <a class="nav-item" href="https://sambulosenda.github.io/expo-bug-report/" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
      <span class="nav-item-label">Docs</span>
    </a>
    <a class="nav-item" href="#">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 0 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
      <span class="nav-item-label">Settings</span>
    </a>
  </nav>

  <main class="dash-main">
    <header class="topbar">
      <button class="topbar-hamburger" id="nav-toggle" aria-label="Toggle navigation">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
      </button>
      <h1 class="topbar-title">{pageTitle || title}</h1>
      <div class="topbar-actions">
        <input type="text" class="topbar-search" placeholder="Search bugs..." aria-label="Search bugs">
        <div class="avatar" id="user-avatar">--</div>
        <button class="btn btn-sm" id="logout-btn">Logout</button>
      </div>
    </header>
    <div class="dash-content">
      <slot />
    </div>
  </main>

  <style is:global>
    /* ===== Nav Rail ===== */
    .nav-rail {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: var(--nav-rail-width);
      background: var(--inset);
      border-right: 1px solid var(--border-subtle);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 16px 0;
      gap: 4px;
      z-index: 100;
      transition: width 300ms ease-in-out;
      overflow: hidden;
    }
    .nav-rail:hover { width: var(--nav-rail-expanded); }

    .nav-rail-logo {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      flex-shrink: 0;
    }
    .nav-rail-logo svg { width: 20px; height: 20px; }

    .nav-item {
      width: 100%;
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      border-radius: var(--radius);
      color: var(--text-ghost);
      transition: color 150ms ease-out, background 150ms ease-out;
      cursor: pointer;
      white-space: nowrap;
      text-decoration: none;
    }
    .nav-item:hover { color: var(--text); background: var(--surface-hover); }
    .nav-item.active { color: var(--accent); background: var(--accent-muted); }
    .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }

    .nav-item-label {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 500;
      opacity: 0;
      transition: opacity 150ms ease-out;
    }
    .nav-rail:hover .nav-item-label { opacity: 1; }

    .nav-spacer { flex: 1; }

    /* ===== Main Area ===== */
    .dash-main {
      margin-left: var(--nav-rail-width);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ===== Top Bar ===== */
    .topbar {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 24px;
      border-bottom: 1px solid var(--border-subtle);
      background: var(--surface);
    }
    .topbar-hamburger {
      display: none;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      color: var(--text);
      cursor: pointer;
      padding: 4px;
    }
    .topbar-title {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 600;
      letter-spacing: -0.01em;
      flex: 1;
    }
    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .topbar-search {
      background: var(--inset);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 6px 12px;
      color: var(--text);
      font-family: var(--font-body);
      font-size: 13px;
      width: 200px;
      outline: none;
      transition: border-color 150ms ease-out, transform 75ms ease-out;
    }
    .topbar-search:focus { border-color: var(--accent); transform: translateY(1px); }
    .topbar-search::placeholder { color: var(--text-ghost); }

    .avatar {
      width: 28px;
      height: 28px;
      border-radius: 9999px;
      background: var(--accent-muted);
      border: 1px solid var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 600;
      color: var(--accent);
    }
    .btn-sm { padding: 4px 12px; font-size: 12px; }

    /* ===== Content Area ===== */
    .dash-content {
      flex: 1;
      padding: 24px;
      max-width: 1400px;
    }

    /* ===== Mobile ===== */
    @media (max-width: 768px) {
      .nav-rail { display: none; }
      .nav-rail.nav-rail--open {
        display: flex;
        width: var(--nav-rail-expanded);
        box-shadow: 4px 0 24px rgba(0,0,0,0.5);
      }
      .nav-rail.nav-rail--open .nav-item-label { opacity: 1; }
      .dash-main { margin-left: 0; }
      .topbar-hamburger { display: flex; }
      .dash-content { padding: 16px; }
      .topbar-search { width: 140px; }
    }

    @media (max-width: 375px) {
      .topbar { padding: 8px 16px; }
      .topbar-search { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>

  <script is:inline>
    // Auth check
    if (window.__bp && !window.__bp.isLoggedIn()) {
      window.location.href = '/login';
    }

    // Logout
    var logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', async function() {
        if (window.__bp) {
          await window.__bp.fetch('/v1/auth/logout', { method: 'POST' });
          window.__bp.logout();
        }
        window.location.href = '/login';
      });
    }

    // Mobile hamburger
    var navToggle = document.getElementById('nav-toggle');
    var navRail = document.querySelector('.nav-rail');
    if (navToggle && navRail) {
      navToggle.addEventListener('click', function() {
        navRail.classList.toggle('nav-rail--open');
      });
      // Close on nav item click (mobile)
      navRail.querySelectorAll('.nav-item').forEach(function(item) {
        item.addEventListener('click', function() {
          navRail.classList.remove('nav-rail--open');
        });
      });
    }
  </script>
</Layout>
